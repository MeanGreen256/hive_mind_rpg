; Engine configuration file.
; Edit through the Godot editor when possible because some values are not
; self-explanatory.
;
; Format:
;   [section]
;   param=value

config_version=5

[application]

config/name="hive_mind_rpg"
config/features=PackedStringArray("4.7")
run/main_scene="res://scenes/main/main.tscn"

[autoload]

GameState="*res://scripts/autoload/game_state.gd"
TimeScaleManager="*res://scripts/autoload/time_scale_manager.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"

[display/window]

size/viewport_width=640
size/viewport_height=360
size/window_width_override=1920
size/window_height_override=1080
stretch/mode="canvas_items"
stretch/aspect="keep"
stretch/scale_mode="integer"

[input]

move_up={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"device":-1,"physical_keycode":87), Object(InputEventJoypadMotion,"resource_local_to_scene":false,"device":-1,"axis":1,"axis_value":-1.0), Object(InputEventJoypadButton,"resource_local_to_scene":false,"device":-1,"button_index":11)]
}
move_down={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"device":-1,"physical_keycode":83), Object(InputEventJoypadMotion,"resource_local_to_scene":false,"device":-1,"axis":1,"axis_value":1.0), Object(InputEventJoypadButton,"resource_local_to_scene":false,"device":-1,"button_index":12)]
}
move_left={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"device":-1,"physical_keycode":65), Object(InputEventJoypadMotion,"resource_local_to_scene":false,"device":-1,"axis":0,"axis_value":-1.0), Object(InputEventJoypadButton,"resource_local_to_scene":false,"device":-1,"button_index":13)]
}
move_right={
