}
dash={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"device":-1,"physical_keycode":32), Object(InputEventJoypadButton,"resource_local_to_scene":false,"device":-1,"button_index":0)]
}
attack_melee={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"device":-1,"physical_keycode":74), Object(InputEventJoypadButton,"resource_local_to_scene":false,"device":-1,"button_index":2)]
}
ability_relic={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"device":-1,"physical_keycode":75), Object(InputEventJoypadButton,"resource_local_to_scene":false,"device":-1,"button_index":3)]
}
interact={
